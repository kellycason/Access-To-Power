{
  "name": "access-to-power",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "description": "Power Apps Code App that migrates Microsoft Access databases to Dataverse.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc -b --noEmit",
    "helper:package": "powershell.exe -ExecutionPolicy Bypass -File scripts/package-helper-installer.ps1",
    "power:init": "power-apps init",
    "power:run": "power-apps run",
    "power:push": "power-apps push"
  },
  "dependencies": {
    "@microsoft/power-apps": "^1.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
