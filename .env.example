# Copy to `.env.local` and fill in. Values are baked into the build.
# Leaving these unset makes the app use the MockDataverseClient (fixture data).
#
# When running inside the Power Apps host these are unnecessary — the host
# injects the env URL via its own context. For the standalone Vite dev
# server, set them so the wizard can talk to a real Dataverse env.

VITE_DATAVERSE_URL=https://yourorg.crm.dynamics.com
VITE_TENANT_ID=00000000-0000-0000-0000-000000000000
